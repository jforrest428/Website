# Keystone Case Study — Environment Variables
# Copy this file to .env and fill in your keys

# Required: Anthropic API key for all Claude API calls
ANTHROPIC_API_KEY=sk-ant-...

# Optional: ElevenLabs API key for voice synthesis in Product 4
# If absent, the voice receptionist demo will run text-only
ELEVENLABS_API_KEY=

# Optional: ElevenLabs Voice IDs (defaults to a neutral female voice if not set)
ELEVENLABS_VOICE_ID_DAWN=

# Optional: override the data file path (defaults to data/Keystone_Plumbing_Sample_Dataset.xlsx)
DATA_PATH=
