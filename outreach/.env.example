# Sender credentials
# NOTE: Use your business email (josh@forrestanalyticsgroup.com) for best deliverability.
# Sending from an .edu address works but your professional domain looks more credible
# and is less likely to be flagged as personal spam.
GMAIL_ADDRESS=josh@forrestanalyticsgroup.com
GMAIL_APP_PASSWORD=your_16_character_app_password_here

# Follow-up schedule (days after previous touch)
FOLLOW_UP_1_DAYS=4    # Short bump
FOLLOW_UP_2_DAYS=8    # New angle
FOLLOW_UP_3_DAYS=14   # Graceful close

# Daily email cap (initial + follow-ups combined)
DAILY_LIMIT=20

# Delay between emails in seconds (random between MIN and MAX)
# Prevents rate-limit blocks and avoids blast patterns that trigger .edu spam filters
EMAIL_DELAY_MIN=30
EMAIL_DELAY_MAX=90

# Days before the same institution can appear in another batch
# Prevents 5 emails hitting Penn State in 3 days
INSTITUTION_COOLDOWN_DAYS=3
