# ── Sender credentials (Zoho Mail) ───────────────────────────────────────────────
EMAIL_ADDRESS=josh@forrestanalyticsgroup.com

# Zoho App Password (NOT your regular Zoho login password)
# How to get it:
#   1. Log into mail.zoho.com
#   2. Go to: Settings (gear icon) > Security > App Passwords
#   3. Click "Generate New Password", name it "Outreach Script"
#   4. Paste the generated password here
EMAIL_APP_PASSWORD=your_zoho_app_password_here

# ── SMTP settings ────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465

# ── Follow-up schedule (days after previous touch) ───────────────────────────────
FOLLOW_UP_1_DAYS=4
FOLLOW_UP_2_DAYS=8
FOLLOW_UP_3_DAYS=14

# ── Daily cap and send delays ─────────────────────────────────────────────────────
DAILY_LIMIT=20
EMAIL_DELAY_MIN=30
EMAIL_DELAY_MAX=90

# ── University diversity ──────────────────────────────────────────────────────────
INSTITUTION_COOLDOWN_DAYS=3
